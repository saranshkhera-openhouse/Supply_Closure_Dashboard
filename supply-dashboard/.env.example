# Get this from Neon Console → Connection Details → Connection string
DATABASE_URL=postgresql://username:password@ep-xxxxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Get this from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Any random string for signing session cookies
JWT_SECRET=change-this-to-a-random-secret-string

# Any random string for signing session tokens
JWT_SECRET=your-random-secret-string-here

# Get this from Google Cloud Console → APIs & Credentials → OAuth 2.0 Client ID (Web application)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
